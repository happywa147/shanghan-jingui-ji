{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanghan-jingui-ji.local/schemas/import-package.schema.json",
  "title": "伤寒金匮集导入数据包",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest", "editions", "text_units", "alignments", "formulas", "text_formula_links"],
  "properties": {
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "importer", "source_file", "source_id", "source_sha256", "counts"],
      "properties": {
        "schema_version": { "const": 1 },
        "importer": { "type": "string", "minLength": 1 },
        "source_file": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "minLength": 1 },
        "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["editions", "text_units", "alignments", "formulas", "text_formula_links"],
          "properties": {
            "editions": { "type": "integer", "minimum": 0 },
            "text_units": { "type": "integer", "minimum": 0 },
            "alignments": { "type": "integer", "minimum": 0 },
            "formulas": { "type": "integer", "minimum": 0 },
            "text_formula_links": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "editions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "work_id", "source_id", "source_version_id", "name", "description", "numbering_scheme"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "work_id": { "type": "string", "enum": ["shanghan_lun", "jingui_yaolue"] },
          "source_id": { "type": "string", "minLength": 1 },
          "source_version_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "numbering_scheme": { "type": "string", "minLength": 1 }
        }
      }
    },
    "text_units": { "type": "array", "items": { "$ref": "text-unit.schema.json" } },
    "alignments": { "type": "array", "items": { "$ref": "alignment.schema.json" } },
    "formulas": { "type": "array", "items": { "$ref": "formula.schema.json" } },
    "text_formula_links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text_unit_id", "formula_id", "formula_name_raw", "provenance"],
        "properties": {
          "text_unit_id": { "type": "string", "minLength": 1 },
          "formula_id": { "type": "string", "minLength": 1 },
          "formula_name_raw": { "type": "string", "minLength": 1 },
          "provenance": { "type": "string", "enum": ["imported", "algorithm", "human"] }
        }
      }
    }
  }
}
