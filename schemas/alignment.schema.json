{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanghan-jingui-ji.local/schemas/alignment.schema.json",
  "title": "伤寒金匮集跨版本对应关系",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "work_id",
    "source_unit_ids",
    "target_unit_ids",
    "relation_type",
    "provenance",
    "review_status"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "work_id": { "type": "string", "enum": ["shanghan_lun", "jingui_yaolue"] },
    "source_unit_ids": {
      "type": "array",
      "minItems": 0,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "target_unit_ids": {
      "type": "array",
      "minItems": 0,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "relation_type": {
      "type": "string",
      "enum": ["exact", "approximate", "split", "merge", "related", "no_match", "undetermined", "addition", "omission"]
    },
    "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "provenance": { "type": "string", "enum": ["imported", "algorithm", "human"] },
    "algorithm": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "review_status": {
      "type": "string",
      "enum": ["imported", "machine_checked", "human_checked", "approved"]
    },
    "notes": { "type": ["string", "null"] }
  },
  "anyOf": [
    { "properties": { "source_unit_ids": { "type": "array", "minItems": 1 } } },
    { "properties": { "target_unit_ids": { "type": "array", "minItems": 1 } } }
  ]
}
