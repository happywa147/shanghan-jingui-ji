{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanghan-jingui-ji.local/schemas/prepublication-readiness.schema.json",
  "title": "预发布验收状态",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "generator", "inputs", "metrics", "technical_preview", "public_prepublication", "external_gates"],
  "properties": {
    "schema_version": { "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "generator": { "const": "scripts/generate-prepublication-readiness.mjs" },
    "inputs": {
      "type": "array", "minItems": 8,
      "items": { "type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {
        "path": { "type": "string", "minLength": 1 }, "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }}
    },
    "metrics": {
      "type": "object", "additionalProperties": false,
      "required": ["catalog_selected_editions", "selected_image_editions", "ocr_target_pages", "ocr_completed_pages", "anchors_total", "anchors_human_verified", "verified_human_experts", "human_golden_records", "matrix_state", "review_workflow_evidence", "website_required_files", "website_present_files"],
      "properties": {
        "catalog_selected_editions": { "type": "integer", "minimum": 0 },
        "selected_image_editions": { "type": "integer", "minimum": 0 },
        "ocr_target_pages": { "type": "integer", "minimum": 0 }, "ocr_completed_pages": { "type": "integer", "minimum": 0 },
        "anchors_total": { "type": "integer", "minimum": 0 }, "anchors_human_verified": { "type": "integer", "minimum": 0 },
        "verified_human_experts": { "type": "integer", "minimum": 0 }, "human_golden_records": { "type": "integer", "minimum": 0 },
        "matrix_state": { "enum": ["blocked", "ready"] }, "review_workflow_evidence": { "enum": ["PASS", "FAIL"] },
        "website_required_files": { "type": "integer", "minimum": 1 }, "website_present_files": { "type": "integer", "minimum": 0 }
      }
    },
    "technical_preview": { "$ref": "#/$defs/gate" },
    "public_prepublication": { "$ref": "#/$defs/gate" },
    "external_gates": {
      "type": "object", "additionalProperties": false,
      "required": ["copyright", "website_release"],
      "properties": {
        "copyright": { "const": "npm run verify:release-rights" },
        "website_release": { "const": "npm run test:e2e && npm run verify:artifacts" }
      }
    }
  },
  "$defs": {
    "gate": {
      "type": "object", "additionalProperties": false,
      "required": ["ready", "checks", "blockers"],
      "properties": {
        "ready": { "type": "boolean" },
        "checks": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["id", "required", "actual", "pass"], "properties": {
          "id": { "type": "string", "minLength": 1 }, "required": {}, "actual": {}, "pass": { "type": "boolean" }
        }}},
        "blockers": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
