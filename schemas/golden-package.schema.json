{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shanghan-jingui-ji.local/schemas/golden-package.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "input_revision", "variant_revision", "generator", "algorithm_version", "promotion_rule", "candidates"],
  "properties": {
    "schema_version": { "const": 1 },
    "input_revision": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "variant_revision": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "generator": { "const": "scripts/generate-golden-candidates.mjs" },
    "algorithm_version": { "type": "string", "minLength": 1 },
    "promotion_rule": { "type": "string", "minLength": 1 },
    "candidates": { "type": "array", "minItems": 1, "items": { "$ref": "https://shanghan-jingui-ji.local/schemas/golden-candidate.schema.json" } }
  }
}
