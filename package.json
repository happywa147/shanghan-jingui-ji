{
  "name": "shanghan-jingui-ji",
  "version": "0.4.0",
  "private": true,
  "engines": {
    "node": ">=22.18.0 <23"
  },
  "type": "module",
  "scripts": {
    "test": "node --test",
    "test:e2e": "playwright test",
    "test:e2e:pr": "playwright test --project=chromium --project=webkit",
    "check:release": "npm test && npm run verify:import && npm run verify:integrity && npm run generate:variants && npm run generate:golden-candidates && npm run validate:schemas && npm run generate:formula-variants && npm run generate:quality && npm run generate:report && npm run generate:formula-report && npm run verify:quality-gates",
    "check": "npm test && npm run import:liwengtang && npm run verify:import && npm run verify:sources && npm run generate:variants && npm run generate:golden-candidates && npm run validate:schemas && npm run generate:formula-variants && npm run generate:quality && npm run generate:report && npm run generate:formula-report && npm run status",
    "setup:sources": "node scripts/download-sources.mjs",
    "status": "node scripts/status.mjs",
    "import:liwengtang": "node scripts/import-liwengtang.mjs ../liwengtang/shanghan_data/shanghan_all.json",
    "verify:import": "node scripts/verify-import.mjs",
    "verify:integrity": "node scripts/verify-dataset-integrity.mjs",
    "validate:schemas": "node scripts/validate-schemas.mjs",
    "verify:quality-gates": "node scripts/verify-quality-gates.mjs",
    "verify:sources": "node scripts/verify-sources.mjs",
    "verify:ocr": "node scripts/verify-ocr.mjs data/imported/jingui-sibu-1-ocr.json data/imported/jingui-sibu-2-ocr.json",
    "generate:variants": "node scripts/generate-variants.mjs",
    "generate:golden-candidates": "node scripts/generate-golden-candidates.mjs",
    "review:promote-golden": "node scripts/promote-golden-candidates.mjs",
    "generate:report": "node scripts/generate-report.mjs",
    "generate:quality": "node scripts/generate-quality-report.mjs",
    "generate:formula-variants": "node scripts/generate-formula-variants.mjs",
    "generate:formula-report": "node scripts/generate-formula-report.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.61.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "http-server": "^14.1.1"
  }
}
